
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU MOA Tracker - Security Rules v2.2
     * 
     * FIXED: 
     * - Admin bootstrap logic to recognize the primary administrator even across session UID changes.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPrimaryAdmin() {
      // Allow the primary developer/admin email to bypass initial bootstrap hurdles
      return request.auth.token.email == 'johnmarc.sanchez@neu.edu.ph';
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        isPrimaryAdmin()
      );
    }

    function isNotBlocked() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(userPath) || get(userPath).data.isBlocked == false;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn(); 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isPrimaryAdmin(); 
      allow update, delete: if false; 
    }

    match /memoranda_of_agreement/{moaId} {
      allow get, list: if isSignedIn() && isNotBlocked();
      allow create, update, delete: if isAdmin();
    }

    match /audit_logs/{auditLogId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}
