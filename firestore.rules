rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU MOA Tracker - Security Rules v2.1
     * 
     * FIXED: 
     * - Allows authenticated users to query the 'users' collection for their own profile.
     * - Fixes 'isNotBlocked' to handle new users (non-existent docs).
     * - Updates bootstrap logic for the designated admin.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isNotBlocked() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      // If doc doesn't exist, they aren't blocked yet. If it does, check the field.
      return !exists(userPath) || get(userPath).data.isBlocked == false;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Allow 'list' so users can find their profile by email during login handshake
      allow get, list: if isSignedIn(); 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow the designated primary admin to self-bootstrap
      // In a real app, this would be restricted to a specific UID after the first deploy
      allow create: if isOwner(userId); 
      allow update, delete: if false; 
    }

    match /memoranda_of_agreement/{moaId} {
      allow get, list: if isSignedIn() && isNotBlocked();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /audit_logs/{auditLogId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}