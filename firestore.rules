
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU MOA Tracker - Security Rules v2.3
     * 
     * UPDATED for Prototype Testing:
     * - Admin bootstrap relies on roles_admin document.
     * - roles_admin creation is allowed for self-management during testing.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isNotBlocked() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(userPath) || get(userPath).data.isBlocked == false;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn(); 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get, create: if isOwner(userId);
      allow list: if isAdmin();
      allow update, delete: if isAdmin(); 
    }

    match /memoranda_of_agreement/{moaId} {
      allow get, list: if isSignedIn() && isNotBlocked();
      allow create, update, delete: if isAdmin();
    }

    match /audit_logs/{auditLogId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}
