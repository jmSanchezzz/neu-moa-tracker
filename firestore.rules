
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function hasAdminClaim() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function hasAdminRegistry() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isAdmin() {
      return hasAdminClaim() || hasAdminRegistry();
    }

    function isAuthorizedFaculty() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && exists(userPath) && 
             get(userPath).data.role == 'FACULTY' && 
             get(userPath).data.canEdit == true;
    }

    // Prototype accounts sign in anonymously.
    function isPrototypeUser() {
      return isSignedIn() && (
        request.auth.token.firebase.sign_in_provider == 'anonymous' ||
        request.auth.token.firebase.sign_in_provider == 'custom'
      );
    }

    function isNotBlocked() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      // New users (not yet in the users collection) are allowed to read MOAs to see the directory
      return isPrototypeUser() || !exists(userPath) || get(userPath).data.isBlocked != true;
    }

    function isPrototypeSelf(userId) {
      return isPrototypeUser() && request.auth.uid == userId;
    }

    function isSelfSafeUpdate() {
      // Prevents users from promoting themselves or unblocking themselves
      return request.resource.data.role == resource.data.role &&
             request.resource.data.canEdit == resource.data.canEdit &&
             request.resource.data.isBlocked == resource.data.isBlocked;
    }

    function isSelfSafeCreate() {
      // Ensures new self-registered users are always read-only students
      return request.resource.data.id == request.auth.uid &&
             request.resource.data.role == 'STUDENT' &&
             request.resource.data.canEdit == false &&
             request.resource.data.isBlocked == false;
    }

    function validateStatus(data) {
      let pStatus = data.primaryStatus;
      let sStatus = data.subStatus;
      
      return (pStatus == 'PROCESSING' && sStatus in ['AWAITING_HTE_SIGNATURE', 'LEGAL_REVIEW', 'VPAA_APPROVAL']) ||
             (pStatus == 'APPROVED' && sStatus in ['SIGNED_BY_PRESIDENT', 'ONGOING_NOTARIZATION', 'NO_NOTARIZATION_NEEDED']) ||
             (pStatus == 'EXPIRED' && sStatus in ['NO_RENEWAL_DONE']);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();

      // Users can create their own profile as STUDENT, or Admins can create any profile
      allow create: if isPrototypeSelf(userId) ||
                    isAdmin() ||
                    (isSignedIn() && request.auth.uid == userId);

      // Users can update their own non-permission fields, or Admins can update anything
      allow update: if isPrototypeSelf(userId) ||
                    isAdmin() ||
                    (isSignedIn() && request.auth.uid == userId && isSelfSafeUpdate());
                    
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;

      // Allow designated institutional admins to bootstrap their own registry
      allow create, update: if isPrototypeSelf(userId) ||
                            (request.auth.uid == userId &&
                             request.auth.token.email.matches('(?i)^(johnmarc\\.sanchez@neu\\.edu\\.ph|jcesperanza@neu\\.edu\\.ph|clarklawrence\\.ching@neu\\.edu\\.ph)$'));
                            
      allow list, delete: if isAdmin(); 
    }

    match /memoranda_of_agreement/{moaId} {
      allow read: if isSignedIn() && isNotBlocked();
      
      allow create, update: if (isAdmin() || isAuthorizedFaculty()) && 
                             validateStatus(request.resource.data) &&
                             request.resource.data.expirationDate is timestamp;
      
      allow delete: if isAdmin();
    }

    match /audit_logs/{auditLogId} {
      allow read: if isAdmin();
      // Allow audited writes from trusted editors while preserving admin-only visibility.
      allow write: if isAdmin() || isAuthorizedFaculty();
    }

    match /system_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}