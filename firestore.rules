
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU MOA Tracker - Security Rules v2.4
     * 
     * Refined for Anonymous Institutional Testing:
     * - Allows self-bootstrap for Admins.
     * - Robust checks for blocked status.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isNotBlocked() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      // If user doc doesn't exist yet (initial login), they are not blocked.
      // If it exists, check the isBlocked field.
      return !exists(userPath) || get(userPath).data.isBlocked == false;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn(); 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      // Allow user to check/create their own admin status
      allow get, create: if isOwner(userId);
      // Standard admin management
      allow list, update, delete: if isAdmin(); 
    }

    match /memoranda_of_agreement/{moaId} {
      allow get, list: if isSignedIn() && isNotBlocked();
      allow create, update, delete: if isAdmin();
    }

    match /audit_logs/{auditLogId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}
